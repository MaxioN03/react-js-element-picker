{
  "name": "react-js-element-picker",
  "version": "0.2.0",
  "description": "React TypeScript library for selecting elements on a web page",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "start": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxioN03/react-js-element-picker.git"
  },
  "keywords": [
    "react",
    "element",
    "pick",
    "picker",
    "web",
    "browser",
    "DOM",
    "JavaScript",
    "TypeScript",
    "customization"
  ],
  "author": "maxion03",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MaxioN03/react-js-element-picker/issues"
  },
  "homepage": "https://github.com/MaxioN03/react-js-element-picker#readme",
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "rollup": "^4.60.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^6.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "js-element-picker": "^1.0.1"
  }
}
